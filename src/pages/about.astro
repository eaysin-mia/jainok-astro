---
import Breadcrumbs from '@/components/breadcrumbs.astro'
import Link from '@/components/link.astro'
import PageHead from '@/components/page-head.astro'
import ProjectCard from '@/components/project-card.astro'
import Layout from '@/layouts/layout.astro'
import { getAllProjects } from '@/lib/data-utils'

const projects = await getAllProjects()
---

<Layout class="max-w-3xl">
  <PageHead slot="head" title="About" />
  <Breadcrumbs items={[{ label: 'About', icon: 'lucide:info' }]} />

  <section>
    <div class="min-w-full">
      <div class="prose mb-8">
        <p class="mt-0">
          I’m a <strong>Full Stack Engineer</strong> based in Rajshahi, Bangladesh, currently
          working at <strong>Next Level Media</strong> (Global Branch). I specialize in
          building large-scale, complex products like ERPs and healthcare
          platforms that require solid backend architecture and real business
          workflows.
        </p>
        <p>
          I have shipped production systems for US enterprise teams, the Zambian
          government healthcare system, and various global enterprise clients.
          My expertise spans the <strong>MERN stack</strong>, AI-powered insights, and
          specialized API integrations (Google Ads, Twilio A2P).
        </p>

        <h3 class="text-xl font-medium mt-8 mb-4">Work Experience</h3>
        <ul class="list-none p-0 space-y-6">
          <li>
            <div class="flex flex-col sm:flex-row sm:justify-between items-baseline mb-1">
              <span class="font-medium text-foreground">Next Level Media — Full Stack Engineer</span>
              <span class="text-sm text-muted-foreground italic">04/2025 – Present</span>
            </div>
            <p class="text-sm text-muted-foreground leading-relaxed">
              Core contributor to *My Manager* ERP. Specifically responsible for Google Ads management via REST APIs, 
              Twilio A2P 10DLC SMS automation, and employee scheduling systems. Implemented ticketing/seating 
              from scratch and AI-powered dynamic reporting.
            </p>
          </li>
          <li>
            <div class="flex flex-col sm:flex-row sm:justify-between items-baseline mb-1">
              <span class="font-medium text-foreground">Blackrock IT Solutions (US-Remote) — Software Engineer</span>
              <span class="text-sm text-muted-foreground italic">03/2024 – 12/2024</span>
            </div>
            <p class="text-sm text-muted-foreground leading-relaxed">
              Led the reporting module for *Hybrid Chart Evolve*. Developed healthcare provider scheduling 
              systems managing patient flow, census, and permissions across multiple facilities.
            </p>
          </li>
          <li>
            <div class="flex flex-col sm:flex-row sm:justify-between items-baseline mb-1">
              <span class="font-medium text-foreground">Excel Technologies Ltd — Frontend Developer</span>
              <span class="text-sm text-muted-foreground italic">01/2023 – 02/2024</span>
            </div>
            <p class="text-sm text-muted-foreground leading-relaxed">
              Focused on *SmartCare Pro*, a comprehensive medical record system for Zambian health facilities. 
              Built specialized modules for ANC, treatment plans, and vital tracking.
            </p>
          </li>
        </ul>
      </div>

      <h2 class="mb-4 text-2xl font-medium">Selected Projects</h2>
      <div class="flex flex-col gap-4">
        {projects.map((project) => <ProjectCard project={project} />)}
      </div>
    </div>
  </section>
</Layout>
