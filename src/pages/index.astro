---
import AuthorCard from '@/components/author-card.astro'
import BlogCard from '@/components/blog-card.astro'
import Link from '@/components/link.astro'
import PageHead from '@/components/page-head.astro'
import ProjectCard from '@/components/project-card.astro'
import { buttonVariants } from '@/components/ui/button'
import { SITE } from '@/consts'
import Layout from '@/layouts/layout.astro'
import { getAllPosts, getAllProjects, getRecentPosts } from '@/lib/data-utils'
import { getEntry } from 'astro:content'

const author = await getEntry('authors', 'eaysin')
const projects = await getAllProjects()
const allPosts = await getAllPosts()
const blog = await getRecentPosts(SITE.featuredPostCount)
const hasMorePosts = allPosts.length > SITE.featuredPostCount
---

<Layout class="max-w-3xl">
  <PageHead slot="head" title="Home" />
  <section class="rounded-lg border">
    {author && <AuthorCard author={author} />}
    <div class="p-6 pt-0">
      <p class="text-muted-foreground mb-2 text-sm text-balance">
        I’m a <strong>Full Stack Engineer</strong> at <strong>Next Level Media</strong>, where I build
        large-scale ERP systems. I currently own core modules for <strong>My Manager</strong>,
        including Google Ads API management, Twilio A2P automation, and complex
        employee scheduling systems.
      </p>
      <p class="text-muted-foreground text-sm text-balance">
        With 2+ years of experience across the <strong>ERP and Healthcare</strong> sectors, I
        build production-ready products that solve complex business workflows.
        You can also find my work on <Link
          href="https://github.com/eaysin-mia"
          class="text-foreground font-medium"
          underline
          external>GitHub</Link
        >.
      </p>
    </div>
  </section>

  <section class="flex flex-col gap-y-4">
    <h2 class="text-2xl font-medium">Latest blogs</h2>
    <ul class="flex flex-col gap-y-4">
      {
        blog.map((post) => (
          <li>
            <BlogCard entry={post} />
          </li>
        ))
      }
    </ul>
    {
      hasMorePosts && (
        <div class="flex justify-center">
          <Link
            href="/blog"
            class={buttonVariants({ variant: 'ghost' }) + ' group'}
          >
            See all blogs
            <span class="ml-1.5 transition-transform group-hover:translate-x-1">
              &rarr;
            </span>
          </Link>
        </div>
      )
    }
  </section>

  <section class="flex flex-col gap-y-4">
    <h2 class="text-2xl font-medium">Selected Projects</h2>
    <ul class="flex flex-col gap-y-4">
      {
        projects.slice(0, 3).map((project) => (
          <li>
            <ProjectCard project={project} />
          </li>
        ))
      }
    </ul>
    <div class="flex justify-center">
      <Link
        href="/about"
        class={buttonVariants({ variant: 'ghost' }) + ' group'}
      >
        See more projects
        <span class="ml-1.5 transition-transform group-hover:translate-x-1">
          &rarr;
        </span>
      </Link>
    </div>
  </section>
</Layout>
