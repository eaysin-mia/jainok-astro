---
import BlogCard from '@/components/blog-card.astro'
import Link from '@/components/link.astro'
import PageHead from '@/components/page-head.astro'
import { buttonVariants } from '@/components/ui/button'
import { SITE } from '@/consts'
import Layout from '@/layouts/layout.astro'
import { getRecentPosts } from '@/lib/data-utils'

const blog = await getRecentPosts(SITE.featuredPostCount)
---

<Layout class="max-w-3xl">
  <PageHead slot="head" title="Home" />
  <section class="rounded-lg border">
    <div class="flex flex-col space-y-1.5 p-6">
      <h3 class="text-3xl leading-none font-medium">Eaysin Mia</h3>
      <p class="text-muted-foreground text-sm">
        Senior Full Stack Engineer
      </p>
    </div>
    <div class="p-6 pt-0">
      <p class="text-muted-foreground mb-2 text-sm">
        I build scalable web products across the stack, with strong experience
        in ERP systems, healthcare platforms, workflow automation, analytics,
        and AI-powered applications.
      </p>
      <p class="text-muted-foreground text-sm">
        I’m currently working at <Link
          href="https://www.linkedin.com/in/meet-eaysin/"
          class="text-foreground"
          underline
          external>Next Level Media</Link
        >, where I contribute to large-scale MERN products covering scheduling,
        reporting, ticketing, campaign management, and Twilio and Google API
        integrations. You can also find my work on <Link
          href="https://github.com/meet-eaysin"
          class="text-foreground"
          underline
          external>GitHub</Link
        > and in my <Link
          href="/eaysin-mia-resume.pdf"
          class="text-foreground"
          underline>resume</Link
        >.
      </p>
    </div>
  </section>
  <section class="flex flex-col gap-y-4">
    <h2 class="text-2xl font-medium">Latest posts</h2>
    <ul class="flex flex-col gap-y-4">
      {
        blog.map((post) => (
          <li>
            <BlogCard entry={post} />
          </li>
        ))
      }
    </ul>
    <div class="flex justify-center">
      <Link
        href="/blog"
        class={buttonVariants({ variant: 'ghost' }) + ' group'}
      >
        See all posts <span
          class="ml-1.5 transition-transform group-hover:translate-x-1"
          >&rarr;</span
        >
      </Link>
    </div>
  </section>
</Layout>
